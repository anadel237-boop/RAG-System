# Medical RAG System Environment Configuration
# Copy this file to .env and fill in your credentials

# Neon PostgreSQL Connection (required)
# Sign up at https://neon.tech and create a database with pgvector extension
NEON_CONNECTION_STRING=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# ClinicalBERT Configuration (no API key needed - uses local model)
# CLINICALBERT_MODEL=emilyalsentzer/Bio_ClinicalBERT

# System Configuration
FLASK_HOST=localhost
FLASK_PORT=5557
DEBUG=False

# Vector Database Settings
VECTOR_DIMENSION=768
SIMILARITY_THRESHOLD=0.7
MAX_RESULTS=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG Settings
RETRIEVAL_TOP_K=5
CONTEXT_WINDOW=4000
MAX_TOKENS=2000
TEMPERATURE=0.1

# Medical Case Settings
CASE_ID_FORMAT=case_XXXX_mimic.txt
MIN_CASE_LENGTH=100
MAX_CASE_LENGTH=10000
